# ==========================================
# ERP System Environment Configuration
# ==========================================

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_secure_password
DB_NAME=vnerp

# JWT Configuration
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Application Configuration
NODE_ENV=development
DEBUG_DB=true

# 开发环境允许的源（逗号分隔，next.config.ts allowedDevOrigins）
# 示例：DEV_ORIGINS=192.168.0.155,192.168.0.157,localhost
DEV_ORIGINS=localhost

# CORS 允许的源（默认 * 用于开发；生产应配置具体域名，如 https://erp.example.com）
CORS_ALLOW_ORIGIN=*

# Optional: Redis Configuration (for future caching)
# REDIS_URL=redis://localhost:6379
