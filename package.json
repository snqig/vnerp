{
  "name": "vnerp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000",
    "dev:webpack": "next dev -p 5000 --webpack",
    "build": "next build",
    "start": "next start -p 5000",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "prepare": "husky",
    "ts-check": "tsc --noEmit",
    "preinstall": "npx only-allow pnpm",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:install": "playwright install",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:studio": "drizzle-kit studio",
    "db:generate": "pnpm dlx drizzle-kit generate",
    "db:push": "pnpm dlx drizzle-kit push",
    "db:migrate": "pnpm dlx drizzle-kit migrate",
    "setup:db": "node scripts/setup-db.mjs",
    "cleanup:events": "node scripts/cleanup-event-processed.mjs",
    "init": "node scripts/init-project.js",
    "init:full": "node scripts/init-project.js --full",
    "migrate": "npx tsx scripts/migrate.ts up",
    "migrate:down": "npx tsx scripts/migrate.ts down",
    "migrate:status": "npx tsx scripts/migrate.ts status",
    "migrate:create": "npx tsx scripts/migrate.ts create",
    "backup": "npx tsx scripts/backup-database.ts",
    "backup:list": "npx tsx scripts/backup-database.ts list",
    "backup:restore": "npx tsx scripts/backup-database.ts restore",
    "docs:api": "node scripts/generate-api-docs.js",
    "i18n:check": "node scripts/i18n-key-check.mjs",
    "i18n:check:strict": "node scripts/i18n-key-check.mjs --strict"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
